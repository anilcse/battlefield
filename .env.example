# App
APP_NAME=nof1-polymarket-clone
APP_ENV=dev

# Database (use localhost for ./start.sh; use db for Docker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nof1

# Polymarket (optional fallback when not set per-model)
POLYMARKET_BASE_URL=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
ENABLE_LIVE_TRADING=false
# 2=Gnosis Safe (Polymarket proxy wallets); 1=Poly Proxy; 0=EOA
POLYMARKET_SIGNATURE_TYPE=2

# OpenRouter (required for model forecasts)
OPENROUTER_API_KEY=

# Auto-claim: uses each model's private_key from MODEL_ACCOUNT_CONFIGS (redeems per-account)
POLYGON_RPC_URL=
AUTO_CLAIM_ENABLED=false
AUTO_CLAIM_INTERVAL_SECONDS=600

# Model config: use env below OR set MODEL_CONFIG_PATH to a JSON file (see model_config.json.example)
# JSON keys: model_names (array or comma string), model_account_configs (object), default_model_monthly_budget_usd
MODEL_CONFIG_PATH=
# Top prediction-market models (OpenRouter): gpt-5.2-pro, claude-sonnet-4.5, claude-opus-4.5, gemini-2.5-pro, deepseek-r1
MODEL_NAMES=openai/gpt-5.2-pro,anthropic/claude-sonnet-4.5,anthropic/claude-opus-4.5,google/gemini-2.5-pro-preview,deepseek/deepseek-r1-0528
DEFAULT_MODEL_MONTHLY_BUDGET_USD=100
MODEL_ACCOUNT_CONFIGS={"openai/gpt-5.2-pro":{"private_key":"","wallet_address":""},"anthropic/claude-sonnet-4.5":{"private_key":"","wallet_address":""},"anthropic/claude-opus-4.5":{"private_key":"","wallet_address":""},"google/gemini-2.5-pro-preview":{"private_key":"","wallet_address":""},"deepseek/deepseek-r1-0528":{"private_key":"","wallet_address":""}}

# Game / tournament
GAME_LOOP_ENABLED=false
# Seconds between rounds; lower = more frequent trading (e.g. 300 = every 5 min)
GAME_LOOP_INTERVAL_SECONDS=300
TOURNAMENT_DURATION_DAYS=7
TOURNAMENT_START_BUDGET_USD=100
GAME_TRADE_SIZE_USD=5
# Min edge to trade (0.12 = 12%); higher = more selective, fewer but better trades
GAME_EDGE_THRESHOLD=0.12
