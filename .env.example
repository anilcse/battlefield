APP_NAME=nof1-polymarket-clone
APP_ENV=dev
API_PORT=8000

DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/nof1

POLYMARKET_BASE_URL=https://clob.polymarket.com
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=
POLYMARKET_CHAIN_ID=137
ENABLE_LIVE_TRADING=false
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_APP_NAME=nof1-polymarket-clone
OPENROUTER_SITE_URL=http://localhost:8000
POLYGON_RPC_URL=
PRIVATE_KEY=
WALLET_ADDRESS=
AUTO_CLAIM_ENABLED=false
AUTO_CLAIM_INTERVAL_SECONDS=600
# JSON map: model_name -> account credentials
# If polymarket_api_* values are empty, backend derives them dynamically from private_key.
MODEL_ACCOUNT_CONFIGS={"openai/gpt-5":{"polymarket_api_key":"","polymarket_secret":"","polymarket_passphrase":"","private_key":"","wallet_address":""},"anthropic/claude-sonnet-4":{"polymarket_api_key":"","polymarket_secret":"","polymarket_passphrase":"","private_key":"","wallet_address":""},"x-ai/grok-4":{"polymarket_api_key":"","polymarket_secret":"","polymarket_passphrase":"","private_key":"","wallet_address":""},"google/gemini-3.1-pro-preview":{"polymarket_api_key":"","polymarket_secret":"","polymarket_passphrase":"","private_key":"","wallet_address":""},"deepseek/deepseek-v3.2-speciale":{"polymarket_api_key":"","polymarket_secret":"","polymarket_passphrase":"","private_key":"","wallet_address":""}}

DEFAULT_MODEL_MONTHLY_BUDGET_USD=100
MODEL_NAMES=openai/gpt-5,anthropic/claude-sonnet-4,x-ai/grok-4,google/gemini-3.1-pro-preview,deepseek/deepseek-v3.2-speciale
GAME_LOOP_ENABLED=false
GAME_LOOP_INTERVAL_SECONDS=3600
TOURNAMENT_DURATION_DAYS=30
TOURNAMENT_START_BUDGET_USD=100
GAME_TRADE_SIZE_USD=5
GAME_EDGE_THRESHOLD=0.10
