# App
APP_NAME=nof1-polymarket-clone
APP_ENV=dev

# Database (use localhost for ./start.sh; use db for Docker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nof1

# Polymarket (optional fallback when not set per-model)
POLYMARKET_BASE_URL=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
ENABLE_LIVE_TRADING=false

# OpenRouter (required for model forecasts)
OPENROUTER_API_KEY=

# Auto-claim: uses each model's private_key from MODEL_ACCOUNT_CONFIGS (redeems per-account)
POLYGON_RPC_URL=
AUTO_CLAIM_ENABLED=false
AUTO_CLAIM_INTERVAL_SECONDS=600

# Model config: use env below OR set MODEL_CONFIG_PATH to a JSON file (see model_config.json.example)
# JSON keys: model_names (array or comma string), model_account_configs (object), default_model_monthly_budget_usd
MODEL_CONFIG_PATH=
MODEL_NAMES=openai/gpt-5,anthropic/claude-sonnet-4,x-ai/grok-4,google/gemini-3.1-pro-preview,deepseek/deepseek-v3.2-speciale
DEFAULT_MODEL_MONTHLY_BUDGET_USD=100
MODEL_ACCOUNT_CONFIGS={"openai/gpt-5":{"private_key":"","wallet_address":""},"anthropic/claude-sonnet-4":{"private_key":"","wallet_address":""},"x-ai/grok-4":{"private_key":"","wallet_address":""},"google/gemini-3.1-pro-preview":{"private_key":"","wallet_address":""},"deepseek/deepseek-v3.2-speciale":{"private_key":"","wallet_address":""}}

# Game / tournament
GAME_LOOP_ENABLED=false
GAME_LOOP_INTERVAL_SECONDS=900
TOURNAMENT_DURATION_DAYS=7
TOURNAMENT_START_BUDGET_USD=100
GAME_TRADE_SIZE_USD=5
GAME_EDGE_THRESHOLD=0.08
